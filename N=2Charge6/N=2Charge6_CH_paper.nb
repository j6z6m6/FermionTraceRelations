Cell[BoxData[
 RowBox[{
  RowBox[{"RowReduceWithTracking", "[", 
   RowBox[{"matrix_", "?", "MatrixQ"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "A", ",", "nRows", ",", "nCols", ",", "pivotRow", ",", "pivotCol", ",", 
      "pivot", ",", "scale", ",", "i", ",", "factor", ",", "pos", ",", 
      "operations"}], "}"}], ",", 
    RowBox[{
     RowBox[{"A", "=", "matrix"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"nRows", ",", "nCols"}], "}"}], "=", 
      RowBox[{"Dimensions", "[", "A", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"operations", "=", 
      RowBox[{"{", "}"}]}], ";", 
     RowBox[{"(*", 
      RowBox[{
      "Initialize", " ", "the", " ", "list", " ", "to", " ", "store", " ", 
       "operations"}], "*)"}], 
     RowBox[{"pivotRow", "=", "1"}], ";", "\[IndentingNewLine]", 
     RowBox[{"pivotCol", "=", "1"}], ";", "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"pivotRow", "<=", "nRows"}], "&&", 
        RowBox[{"pivotCol", "<=", "nCols"}]}], ",", 
       RowBox[{"(*", 
        RowBox[{
        "Extract", " ", "the", " ", "current", " ", "column", " ", "from", " ",
          "the", " ", "pivotRow", " ", "downward"}], "*)"}], 
       RowBox[{
        RowBox[{"pivot", "=", 
         RowBox[{"A", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"pivotRow", ";;"}], ",", "pivotCol"}], "]"}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Find", " ", "the", " ", "first", " ", "non"}], "-", 
          RowBox[{
          "zero", " ", "entry", " ", "in", " ", "the", " ", "current", " ", 
           "pivot", " ", "column"}]}], "*)"}], 
        RowBox[{"pos", "=", 
         RowBox[{"FirstPosition", "[", 
          RowBox[{"pivot", ",", 
           RowBox[{"x_", "/;", 
            RowBox[{"x", "!=", "0"}]}], ",", 
           RowBox[{"Missing", "[", "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"pos", "===", 
           RowBox[{"Missing", "[", "]"}]}], ",", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{
            "No", " ", "pivot", " ", "in", " ", "this", " ", "column"}], ",", 
            RowBox[{
            "move", " ", "to", " ", "the", " ", "next", " ", "column"}]}], 
           "*)"}], 
          RowBox[{"pivotCol", "++"}], ",", 
          RowBox[{"(*", 
           RowBox[{"Pivot", " ", "found"}], "*)"}], 
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", "actualRow", "}"}], ",", 
            RowBox[{
             RowBox[{"actualRow", "=", 
              RowBox[{"pivotRow", "+", 
               RowBox[{"pos", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "-", "1"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{
               RowBox[{
               "If", " ", "the", " ", "pivot", " ", "is", " ", "not", " ", 
                "already", " ", "in", " ", "the", " ", "pivotRow"}], ",", 
               RowBox[{"swap", " ", "rows"}]}], "*)"}], 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"actualRow", "!=", "pivotRow"}], ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"A", "[", 
                  RowBox[{"[", 
                   RowBox[{"{", 
                    RowBox[{"pivotRow", ",", "actualRow"}], "}"}], "]"}], 
                  "]"}], "=", 
                 RowBox[{"A", "[", 
                  RowBox[{"[", 
                   RowBox[{"{", 
                    RowBox[{"actualRow", ",", "pivotRow"}], "}"}], "]"}], 
                  "]"}]}], ";", "\[IndentingNewLine]", 
                RowBox[{"AppendTo", "[", 
                 RowBox[{"operations", ",", 
                  RowBox[{"{", 
                   
                   RowBox[{"\"\<Swap\>\"", ",", "pivotRow", ",", 
                    "actualRow"}], "}"}]}], "]"}], ";"}]}], "]"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{
              "Update", " ", "the", " ", "pivot", " ", "after", " ", 
               "potential", " ", "row", " ", "swap"}], "*)"}], 
             RowBox[{"pivot", "=", 
              RowBox[{"A", "[", 
               RowBox[{"[", 
                RowBox[{"pivotRow", ",", "pivotCol"}], "]"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{
              "Scale", " ", "the", " ", "pivot", " ", "row", " ", "to", " ", 
               "make", " ", "the", " ", "pivot", " ", "element", " ", "equal",
                " ", "to", " ", "1"}], "*)"}], 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"pivot", "!=", "1"}], ",", 
               RowBox[{
                RowBox[{"scale", "=", "pivot"}], ";", "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"A", "[", 
                  RowBox[{"[", "pivotRow", "]"}], "]"}], "=", 
                 RowBox[{
                  RowBox[{"A", "[", 
                   RowBox[{"[", "pivotRow", "]"}], "]"}], "/", "scale"}]}], ";",
                 "\[IndentingNewLine]", 
                RowBox[{"AppendTo", "[", 
                 RowBox[{"operations", ",", 
                  RowBox[{"{", 
                   RowBox[{"\"\<Scale\>\"", ",", "pivotRow", ",", 
                    RowBox[{"1", "/", "scale"}]}], "}"}]}], "]"}], ";"}]}], 
              "]"}], ";", "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{
              "Eliminate", " ", "all", " ", "other", " ", "entries", " ", 
               "in", " ", "the", " ", "pivot", " ", "column"}], "*)"}], 
             RowBox[{"For", "[", 
              RowBox[{
               RowBox[{"i", "=", "1"}], ",", 
               RowBox[{"i", "<=", "nRows"}], ",", 
               RowBox[{"i", "++"}], ",", 
               RowBox[{
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"i", "!=", "pivotRow"}], "&&", 
                   RowBox[{
                    RowBox[{"A", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", ",", "pivotCol"}], "]"}], "]"}], "!=", 
                    "0"}]}], ",", 
                  RowBox[{
                   RowBox[{"factor", "=", 
                    RowBox[{"-", 
                    RowBox[{"A", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", ",", "pivotCol"}], "]"}], "]"}]}]}], ";", 
                   "\[IndentingNewLine]", 
                   RowBox[{
                    RowBox[{"A", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "=", 
                    RowBox[{
                    RowBox[{"A", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "+", 
                    RowBox[{"factor", " ", 
                    RowBox[{"A", "[", 
                    RowBox[{"[", "pivotRow", "]"}], "]"}]}]}]}], ";", 
                   "\[IndentingNewLine]", 
                   RowBox[{"AppendTo", "[", 
                    RowBox[{"operations", ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"\"\<Add\>\"", ",", "pivotRow", ",", "i", ",", 
                    "factor"}], "}"}]}], "]"}], ";"}]}], "]"}], ";"}]}], 
              "]"}], ";", "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{
              "Move", " ", "to", " ", "the", " ", "next", " ", "pivot", " ", 
               "row", " ", "and", " ", "column"}], "*)"}], 
             RowBox[{"pivotRow", "++"}], ";", "\[IndentingNewLine]", 
             RowBox[{"pivotCol", "++"}], ";"}]}], "]"}]}], "]"}]}]}], "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"A", ",", "operations"}], "}"}]}]}], "]"}]}]], "Input",
