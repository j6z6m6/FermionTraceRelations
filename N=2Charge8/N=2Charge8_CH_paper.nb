      RowBox[{"perm", "=", 
       RowBox[{"GroupElements", "[", 
        RowBox[{"SymmetricGroup", "[", "2", "]"}], "]"}]}], ",", 
      RowBox[{"listA", "=", 
       RowBox[{"{", "}"}]}]}], "}"}], ",", 
    RowBox[{
     RowBox[{"listA", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Permute", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"ref1", ",", "ref2"}], "}"}], ",", 
          RowBox[{"perm", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "2"}], "}"}]}], "]"}]}], ";", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"relativesign", "[", 
