       "]"}]}], "]"}], ",", 
    RowBox[{"-", "1"}], ",", 
    RowBox[{"EvenQ", "[", 
     RowBox[{
      RowBox[{"StringCount", "[", 
       RowBox[{
        RowBox[{"ToString", "[", "A1", "]"}], ",", "\"\<\[Psi]\>\""}], "]"}], 
      RowBox[{"StringCount", "[", 
       RowBox[{
        RowBox[{"ToString", "[", "A2", "]"}], ",", "\"\<\[Psi]\>\""}], 
