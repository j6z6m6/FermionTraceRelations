            RowBox[{"Missing", "[", "]"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"pos", "===", 
            RowBox[{"Missing", "[", "]"}]}], ",", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{
             "No", " ", "pivot", " ", "in", " ", "this", " ", "column"}], ",", 
             RowBox[{
             "move", " ", "to", " ", "the", " ", "next", " ", "column"}]}], 
            "*)"}], 
           RowBox[{"pivotCol", "++"}], ",", 
           RowBox[{"(*", 
            RowBox[{"Pivot", " ", "found"}], "*)"}], 
           RowBox[{"Module", "[", 
            RowBox[{
             RowBox[{"{", "actualRow", "}"}], ",", 
             RowBox[{
              RowBox[{"actualRow", "=", 
               RowBox[{"pivotRow", "+", 
                RowBox[{"pos", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "-", "1"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
                RowBox[{
                "If", " ", "the", " ", "pivot", " ", "is", " ", "not", " ", 
                 "already", " ", "in", " ", "the", " ", "pivotRow"}], ",", 
                RowBox[{
                "swap", " ", "rows", " ", "in", " ", "both", " ", "A", " ", 
                 "and", " ", "C"}]}], "*)"}], 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"actualRow", "!=", "pivotRow"}], ",", 
                RowBox[{
                 RowBox[{
                  RowBox[{"A", "[", 
                   RowBox[{"[", 
                    RowBox[{"{", 
                    RowBox[{"pivotRow", ",", "actualRow"}], "}"}], "]"}], 
