 RowBox[{
  RowBox[{"TraceRelationN2", "[", 
   RowBox[{"B_", ",", "A1_", ",", "A2_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
