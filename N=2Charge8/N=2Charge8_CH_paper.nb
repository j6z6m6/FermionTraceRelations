Cell[BoxData[{
 RowBox[{
  RowBox[{"sign", "[", 
   RowBox[{"A1_", ",", "A2_"}], "]"}], ":=", 
  RowBox[{"Which", "[", 
   RowBox[{
    RowBox[{"OddQ", "[", 
     RowBox[{
      RowBox[{"StringCount", "[", 
