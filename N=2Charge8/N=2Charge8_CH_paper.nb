    "one", " ", "need", " ", "to", " ", "track", " ", "the", " ", "number", " ",
      "of", " ", "odd", " ", "cycles", " ", "used"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"CycleSignature", "[", "perm_List", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"temp", "=", 
        RowBox[{
