          RowBox[{"(", 
           RowBox[{
            RowBox[{"Tr", "[", 
             RowBox[{"Dot", "[", 
              RowBox[{"B", ",", "#1", ",", "#2"}], "]"}], "]"}], "-", 
            RowBox[{
             RowBox[{"Tr", "[", 
              RowBox[{"Dot", "[", 
               RowBox[{"B", ",", "#1"}], "]"}], "]"}], "**", 
             RowBox[{"Tr", "[", "#2", "]"}]}], "+", 
            RowBox[{
             FractionBox["1", "2"], "**", 
             RowBox[{"Tr", "[", "B", "]"}], "**", 
             RowBox[{"Tr", "[", "#1", "]"}], "**", 
             RowBox[{"Tr", "[", "#2", "]"}]}], "-", 
            RowBox[{
             FractionBox["1", "2"], "**", 
             RowBox[{"Tr", "[", "B", "]"}], "**", 
             RowBox[{"Tr", "[", 
              RowBox[{"Dot", "[", 
               RowBox[{"#1", ",", "#2"}], "]"}], "]"}]}]}], ")"}]}], "&"}], "@@", 
        RowBox[{"listA", "[", 
