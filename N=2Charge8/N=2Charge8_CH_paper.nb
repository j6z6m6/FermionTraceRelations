                   "]"}]}], ";", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"C", "[", 
                   RowBox[{"[", 
                    RowBox[{"{", 
                    RowBox[{"pivotRow", ",", "actualRow"}], "}"}], "]"}], 
                   "]"}], "=", 
                  RowBox[{"C", "[", 
                   RowBox[{"[", 
                    RowBox[{"{", 
                    RowBox[{"actualRow", ",", "pivotRow"}], "}"}], "]"}], 
                   "]"}]}], ";", "\[IndentingNewLine]", 
                 RowBox[{"AppendTo", "[", 
                  RowBox[{"operations", ",", 
                   RowBox[{"{", 
                    
                    RowBox[{"\"\<Swap\>\"", ",", "pivotRow", ",", 
                    "actualRow"}], "}"}]}], "]"}], ";"}]}], "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
               "Update", " ", "the", " ", "pivot", " ", "after", " ", 
                "potential", " ", "row", " ", "swap"}], "*)"}], 
              RowBox[{"pivot", "=", 
               RowBox[{"A", "[", 
                RowBox[{"[", 
                 RowBox[{"pivotRow", ",", "pivotCol"}], "]"}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
               "Scale", " ", "the", " ", "pivot", " ", "row", " ", "to", " ", 
                "make", " ", "the", " ", "pivot", " ", "element", " ", 
                "equal", " ", "to", " ", "1"}], "*)"}], 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"pivot", "!=", "1"}], ",", 
                RowBox[{
                 RowBox[{"scale", "=", "pivot"}], ";", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"A", "[", 
                   RowBox[{"[", "pivotRow", "]"}], "]"}], "=", 
                  RowBox[{
                   RowBox[{"A", "[", 
                    RowBox[{"[", "pivotRow", "]"}], "]"}], "/", "scale"}]}], ";",
                  "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"C", "[", 
                   RowBox[{"[", "pivotRow", "]"}], "]"}], "=", 
                  RowBox[{
                   RowBox[{"C", "[", 
                    RowBox[{"[", "pivotRow", "]"}], "]"}], "/", "scale"}]}], ";",
                  "\[IndentingNewLine]", 
                 RowBox[{"AppendTo", "[", 
                  RowBox[{"operations", ",", 
                   RowBox[{"{", 
                    RowBox[{"\"\<Scale\>\"", ",", "pivotRow", ",", 
                    RowBox[{"1", "/", "scale"}]}], "}"}]}], "]"}], ";"}]}], 
               "]"}], ";", "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
               "Eliminate", " ", "all", " ", "other", " ", "entries", " ", 
                "in", " ", "the", " ", "pivot", " ", "column"}], "*)"}], 
              RowBox[{"For", "[", 
               RowBox[{
                RowBox[{"i", "=", "1"}], ",", 
                RowBox[{"i", "<=", "nRows"}], ",", 
                RowBox[{"i", "++"}], ",", 
                RowBox[{
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"i", "!=", "pivotRow"}], "&&", 
                    RowBox[{
                    RowBox[{"A", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", ",", "pivotCol"}], "]"}], "]"}], "!=", 
                    "0"}]}], ",", 
                   RowBox[{
                    RowBox[{"factor", "=", 
                    RowBox[{"-", 
                    RowBox[{"A", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", ",", "pivotCol"}], "]"}], "]"}]}]}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"A", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "=", 
                    RowBox[{
                    RowBox[{"A", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "+", 
                    RowBox[{"factor", " ", 
                    RowBox[{"A", "[", 
                    RowBox[{"[", "pivotRow", "]"}], "]"}]}]}]}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{
                    RowBox[{"C", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "=", 
                    RowBox[{
                    RowBox[{"C", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "+", 
                    RowBox[{"factor", " ", 
                    RowBox[{"C", "[", 
                    RowBox[{"[", "pivotRow", "]"}], "]"}]}]}]}], ";", 
                    "\[IndentingNewLine]", 
                    RowBox[{"AppendTo", "[", 
                    RowBox[{"operations", ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"\"\<Add\>\"", ",", "pivotRow", ",", "i", ",", 
                    "factor"}], "}"}]}], "]"}], ";"}]}], "]"}], ";"}]}], 
               "]"}], ";", "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
