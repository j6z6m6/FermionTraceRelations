Cell[CellGroupData[{

Cell["RowReduceWithTracking (From ChatGPT o1-mini ", "Subsection",
 CellChangeTimes->{{3.9388857451722546`*^9, 
  3.938885757406971*^9}},ExpressionUUID->"d36a6d2a-0fd7-7945-a9c3-\
ea43b94dc4a1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"RowReduceWithTracking", "[", 
   RowBox[{"matrix_", "?", "MatrixQ"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "A", ",", "nRows", ",", "nCols", ",", "pivotRow", ",", "pivotCol", ",", 
      "pivot", ",", "scale", ",", "i", ",", "factor", ",", "pos", ",", 
      "operations"}], "}"}], ",", 
    RowBox[{
     RowBox[{"A", "=", "matrix"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"nRows", ",", "nCols"}], "}"}], "=", 
      RowBox[{"Dimensions", "[", "A", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"operations", "=", 
      RowBox[{"{", "}"}]}], ";", 
     RowBox[{"(*", 
      RowBox[{
      "Initialize", " ", "the", " ", "list", " ", "to", " ", "store", " ", 
       "operations"}], "*)"}], 
     RowBox[{"pivotRow", "=", "1"}], ";", "\[IndentingNewLine]", 
     RowBox[{"pivotCol", "=", "1"}], ";", "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"pivotRow", "<=", "nRows"}], "&&", 
        RowBox[{"pivotCol", "<=", "nCols"}]}], ",", 
       RowBox[{"(*", 
        RowBox[{
        "Extract", " ", "the", " ", "current", " ", "column", " ", "from", " ",
          "the", " ", "pivotRow", " ", "downward"}], "*)"}], 
       RowBox[{
        RowBox[{"pivot", "=", 
         RowBox[{"A", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"pivotRow", ";;"}], ",", "pivotCol"}], "]"}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Find", " ", "the", " ", "first", " ", "non"}], "-", 
          RowBox[{
          "zero", " ", "entry", " ", "in", " ", "the", " ", "current", " ", 
           "pivot", " ", "column"}]}], "*)"}], 
        RowBox[{"pos", "=", 
         RowBox[{"FirstPosition", "[", 
          RowBox[{"pivot", ",", 
           RowBox[{"x_", "/;", 
            RowBox[{"x", "!=", "0"}]}], ",", 
           RowBox[{"Missing", "[", "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
