        RowBox[{
         RowBox[{"pivot", "=", 
          RowBox[{"A", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"pivotRow", ";;"}], ",", "pivotCol"}], "]"}], "]"}]}], ";",
          "\[IndentingNewLine]", 
