Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"bigindexlist", "=", 
    RowBox[{"Table", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"indexlist", "=", 
        RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"signtot", "=", "0"}], ";", "\[IndentingNewLine]", 
       RowBox[{"test1", "=", 
        RowBox[{"bignumlist", "[", 
         RowBox[{"[", 
          RowBox[{"i", ",", "j"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"temp1", "=", 
        RowBox[{"CanonicalOrderSingleTrace", "[", "test1", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"indexlist", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"IdUpToSignQ", "[", 
             RowBox[{"temp1", ",", 
              RowBox[{"vectorspace", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", "i", ",", 
            "Nothing"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"Length", "[", "vectorspace", "]"}]}], "}"}]}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"indexlist", "==", 
          RowBox[{"{", "}"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"1", ",", "0"}], "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"test2", "=", 
           RowBox[{"vectorspace", "[", 
            RowBox[{"[", 
             RowBox[{"indexlist", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"sign1", "=", 
           RowBox[{"Product", "[", 
            RowBox[{
             RowBox[{"MutualSign", "[", 
              RowBox[{
               RowBox[{"test1", "[", 
                RowBox[{"[", "i", "]"}], "]"}], ",", 
               RowBox[{"temp1", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1", ",", 
               RowBox[{"Length", "[", "test1", "]"}]}], "}"}]}], "]"}]}], ";",
           "\[IndentingNewLine]", 
          RowBox[{"sign2", "=", 
           RowBox[{"MutualSign", "[", 
            RowBox[{"temp1", ",", "test2"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"signtot", "=", 
           RowBox[{"sign1", " ", "sign2"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"indexlist", "[", 
             RowBox[{"[", "1", "]"}], "]"}], ",", "signtot"}], "}"}]}]}], 
        "]"}]}], "\[IndentingNewLine]", ",", 
      RowBox[{"{", 
