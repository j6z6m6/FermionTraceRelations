     RowBox[{"cycles", "!"}]}]}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Sign", " ", "from", " ", "permutations", " ", "inside", " ", "the", " ", 
     RowBox[{"trace", ".", " ", "If"}], " ", "numebr", " ", "of", " ", 
     "fermions", " ", "is", " ", "odd"}], ",", " ", 
    RowBox[{
    "then", " ", "all", " ", "cycles", " ", "involve", " ", "even", " ", 
     "number", " ", "of", " ", "fermion", " ", "moves"}], ",", " ", 
    RowBox[{
     RowBox[{"so", " ", "no", " ", "sign"}], ";", " ", 
     RowBox[{
     "if", " ", "the", " ", "number", " ", "of", " ", "fermions", " ", "is", " ",
       "even"}]}], ",", " ", 
    RowBox[{
    "one", " ", "need", " ", "to", " ", "track", " ", "the", " ", "number", " ",
      "of", " ", "odd", " ", "cycles", " ", "used"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"CycleSignature", "[", "perm_List", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"temp", "=", 
        RowBox[{
         RowBox[{"CanonicalOrderSingleTrace", "[", 
