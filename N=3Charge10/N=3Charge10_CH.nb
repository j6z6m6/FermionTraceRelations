          "zero", " ", "entry", " ", "in", " ", "the", " ", "current", " ", 
           "pivot", " ", "column"}]}], "*)"}], 
        RowBox[{"pos", "=", 
         RowBox[{"FirstPosition", "[", 
          RowBox[{"pivot", ",", 
           RowBox[{"x_", "/;", 
            RowBox[{"x", "!=", "0"}]}], ",", 
