         RowBox[{"[", "1", "]"}], "]"}]}], ",", 
       RowBox[{"index", "=", "0"}], ",", 
       RowBox[{"cycle", "=", "0"}]}], "}"}], ",", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", "perm", "]"}], "//", "OddQ"}], ",", "1", ",", 
       RowBox[{"(*", 
        RowBox[{
        "First", " ", "find", " ", "the", " ", "cycle", " ", "that", " ", 
