Notebook[{

Cell[CellGroupData[{
Cell["uniqueness_codex", "Title",ExpressionUUID->"f4e7786e-0ffd-9f40-a84a-4c98eb17f805"],

Cell["\<\
Exact finite-order rewrite of uniqueness.nb using coefficient recurrences and \
branch certificates. This notebook avoids global Series/Solve and works with \
exact rational arithmetic throughout.\
\>", "Text",ExpressionUUID->"bb42c23e-c364-1648-92e8-0a637f8ef9ef"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{
   "ZeroSolution", ",", "PeriodicSolution", ",", "DivisorsUpTo", ",", 
    "LogI1Coeffs", ",", "MinusLogOneMinusSeriesCoeffs", ",", 
    "LogIInftyCoeffs", ",", "IdentityResiduals", ",", "VerifyIdentity", ",", 
    "BuildFirstNonzeroConstraint", ",", "BuildAffineStep", ",", 
    "BuildBranchCertificate", ",", "EnumerateNonzeroBranches", ",", 
    "RunEnumerateOrder"}], "]"}], ";"}]], "Input",
 CellLabel->
  "4/21/26 13:56:19 \
In[32]:=",ExpressionUUID->"b474895c-85ac-b34a-be03-5d7ea42c73c1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ZeroSolution", "[", 
    RowBox[{"order_Integer", "?", "NonNegative"}], "]"}], ":=", 
   RowBox[{"ConstantArray", "[", 
    RowBox[{"0", ",", 
     RowBox[{"order", "+", "1"}]}], "]"}]}], ";", 
  RowBox[{
   RowBox[{"PeriodicSolution", "[", 
    RowBox[{
     RowBox[{"period_Integer", "?", "Positive"}], ",", 
     RowBox[{"order_Integer", "?", "NonNegative"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"coeffs", "=", 
       RowBox[{"ZeroSolution", "[", "order", "]"}]}], "}"}], ",", 
     RowBox[{
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"coeffs", "\[LeftDoubleBracket]", 
          RowBox[{"n", "+", "1"}], "\[RightDoubleBracket]"}], "=", 
         RowBox[{"-", "1"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "period", ",", "order", ",", "period"}], "}"}]}], 
       "]"}], ";", "coeffs"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->
  "4/21/26 13:56:19 \
In[33]:=",ExpressionUUID->"76ef7460-bcb2-664d-a8a9-ff6757488ea0"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DivisorsUpTo", "[", 
    RowBox[{"limit_Integer", "?", "NonNegative"}], "]"}], ":=", 
   RowBox[{"Prepend", "[", 
    RowBox[{
     RowBox[{"Divisors", "/@", 
      RowBox[{"Range", "[", "limit", "]"}]}], ",", 
     RowBox[{"{", "}"}]}], "]"}]}], ";", 
  RowBox[{
   RowBox[{"LogI1Coeffs", "[", 
    RowBox[{"a_List", ",", 
     RowBox[{"maxOrder_", ":", "Automatic"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"order", "=", 
        RowBox[{"Replace", "[", 
         RowBox[{"maxOrder", ",", 
          RowBox[{"Automatic", "\[RuleDelayed]", 
           RowBox[{
            RowBox[{"Length", "[", "a", "]"}], "-", "1"}]}]}], "]"}]}], ",", 
       "divisors", ",", "coeffs"}], "}"}], ",", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"order", "\[GreaterEqual]", 
         RowBox[{"Length", "[", "a", "]"}]}], ",", 
        RowBox[{"Return", "[", "$Failed", "]"}]}], "]"}], ";", 
      RowBox[{"divisors", "=", 
       RowBox[{"DivisorsUpTo", "[", "order", "]"}]}], ";", 
      RowBox[{"coeffs", "=", 
       RowBox[{"ConstantArray", "[", 
        RowBox[{"0", ",", 
         RowBox[{"order", "+", "1"}]}], "]"}]}], ";", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"coeffs", "\[LeftDoubleBracket]", 
          RowBox[{"n", "+", "1"}], "\[RightDoubleBracket]"}], "=", 
         RowBox[{"Total", "[", 
          RowBox[{"Table", "[", 
           RowBox[{
            FractionBox[
             RowBox[{"d", " ", 
              RowBox[{"a", "\[LeftDoubleBracket]", 
               RowBox[{"d", "+", "1"}], "\[RightDoubleBracket]"}]}], "n"], ",", 
            RowBox[{"{", 
             RowBox[{"d", ",", 
              RowBox[{"divisors", "\[LeftDoubleBracket]", 
               RowBox[{"n", "+", "1"}], "\[RightDoubleBracket]"}]}], "}"}]}], 
           "]"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "1", ",", "order"}], "}"}]}], "]"}], ";", 
      "coeffs"}]}], "]"}]}], ";", 
  RowBox[{
   RowBox[{"MinusLogOneMinusSeriesCoeffs", "[", 
    RowBox[{"a_List", ",", 
     RowBox[{"maxOrder_", ":", "Automatic"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"order", "=", 
        RowBox[{"Replace", "[", 
         RowBox[{"maxOrder", ",", 
          RowBox[{"Automatic", "\[RuleDelayed]", 
           RowBox[{
            RowBox[{"Length", "[", "a", "]"}], "-", "1"}]}]}], "]"}]}], ",", 
       "coeffs", ",", "total"}], "}"}], ",", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"order", "\[GreaterEqual]", 
         RowBox[{"Length", "[", "a", "]"}]}], ",", 
        RowBox[{"Return", "[", "$Failed", "]"}]}], "]"}], ";", 
      RowBox[{"coeffs", "=", 
       RowBox[{"ConstantArray", "[", 
        RowBox[{"0", ",", 
         RowBox[{"order", "+", "1"}]}], "]"}]}], ";", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"total", "=", 
          RowBox[{
           UnderoverscriptBox["\[Sum]", 
            RowBox[{"k", "=", "1"}], 
            RowBox[{"n", "-", "1"}]], 
           RowBox[{"k", " ", 
            RowBox[{"coeffs", "\[LeftDoubleBracket]", 
             RowBox[{"k", "+", "1"}], "\[RightDoubleBracket]"}], " ", 
            RowBox[{"a", "\[LeftDoubleBracket]", 
             RowBox[{"n", "-", "k", "+", "1"}], 
             "\[RightDoubleBracket]"}]}]}]}], ";", 
         RowBox[{
          RowBox[{"coeffs", "\[LeftDoubleBracket]", 
           RowBox[{"n", "+", "1"}], "\[RightDoubleBracket]"}], "=", 
          RowBox[{
           RowBox[{"a", "\[LeftDoubleBracket]", 
            RowBox[{"n", "+", "1"}], "\[RightDoubleBracket]"}], "+", 
           FractionBox["total", "n"]}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "1", ",", "order"}], "}"}]}], "]"}], ";", 
      "coeffs"}]}], "]"}]}], ";", 
  RowBox[{
   RowBox[{"LogIInftyCoeffs", "[", 
    RowBox[{"a_List", ",", 
     RowBox[{"maxOrder_", ":", "Automatic"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"order", "=", 
        RowBox[{"Replace", "[", 
         RowBox[{"maxOrder", ",", 
          RowBox[{"Automatic", "\[RuleDelayed]", 
           RowBox[{
            RowBox[{"Length", "[", "a", "]"}], "-", "1"}]}]}], "]"}]}], ",", 
       "divisors", ",", "localLog", ",", "coeffs"}], "}"}], ",", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"order", "\[GreaterEqual]", 
         RowBox[{"Length", "[", "a", "]"}]}], ",", 
        RowBox[{"Return", "[", "$Failed", "]"}]}], "]"}], ";", 
      RowBox[{"divisors", "=", 
       RowBox[{"DivisorsUpTo", "[", "order", "]"}]}], ";", 
      RowBox[{"localLog", "=", 
       RowBox[{"MinusLogOneMinusSeriesCoeffs", "[", 
        RowBox[{"a", ",", "order"}], "]"}]}], ";", 
      RowBox[{"coeffs", "=", 
       RowBox[{"ConstantArray", "[", 
        RowBox[{"0", ",", 
         RowBox[{"order", "+", "1"}]}], "]"}]}], ";", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"coeffs", "\[LeftDoubleBracket]", 
          RowBox[{"n", "+", "1"}], "\[RightDoubleBracket]"}], "=", 
         RowBox[{"Total", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"localLog", "\[LeftDoubleBracket]", 
              RowBox[{"#1", "+", "1"}], "\[RightDoubleBracket]"}], "&"}], 
            ")"}], "/@", 
           RowBox[{"divisors", "\[LeftDoubleBracket]", 
            RowBox[{"n", "+", "1"}], "\[RightDoubleBracket]"}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "1", ",", "order"}], "}"}]}], "]"}], ";", 
      "coeffs"}]}], "]"}]}], ";", 
  RowBox[{
   RowBox[{"IdentityResiduals", "[", 
    RowBox[{"a_List", ",", 
     RowBox[{"maxOrder_", ":", "Automatic"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"order", "=", 
       RowBox[{"Replace", "[", 
        RowBox[{"maxOrder", ",", 
         RowBox[{"Automatic", "\[RuleDelayed]", 
          RowBox[{
           RowBox[{"Length", "[", "a", "]"}], "-", "1"}]}]}], "]"}]}], "}"}], 
     ",", 
     RowBox[{
      RowBox[{"LogI1Coeffs", "[", 
       RowBox[{"a", ",", "order"}], "]"}], "-", 
      RowBox[{"LogIInftyCoeffs", "[", 
       RowBox[{"a", ",", "order"}], "]"}]}]}], "]"}]}], ";", 
  RowBox[{
   RowBox[{"VerifyIdentity", "[", 
    RowBox[{"a_List", ",", 
     RowBox[{"maxOrder_", ":", "Automatic"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"order", "=", 
       RowBox[{"Replace", "[", 
        RowBox[{"maxOrder", ",", 
         RowBox[{"Automatic", "\[RuleDelayed]", 
          RowBox[{
           RowBox[{"Length", "[", "a", "]"}], "-", "1"}]}]}], "]"}]}], "}"}], 
     ",", 
     RowBox[{"AllTrue", "[", 
      RowBox[{
       RowBox[{"Rest", "[", 
        RowBox[{"IdentityResiduals", "[", 
         RowBox[{"a", ",", "order"}], "]"}], "]"}], ",", 
       RowBox[{
        RowBox[{"#1", "===", "0"}], "&"}]}], "]"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->
