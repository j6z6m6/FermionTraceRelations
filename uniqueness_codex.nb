In[34]:=",ExpressionUUID->"ecdf8e0b-5931-4f47-8f92-cebbedac7ce9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"BuildFirstNonzeroConstraint", "[", 
    RowBox[{"m_Integer", "?", "Positive"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "x", ",", "coeffs", ",", "residual", ",", "c0", ",", "c1", ",", "c2"}], 
      "}"}], ",", 
     RowBox[{
      RowBox[{"coeffs", "=", 
       RowBox[{"ConstantArray", "[", 
        RowBox[{"0", ",", 
         RowBox[{
          RowBox[{"2", " ", "m"}], "+", "1"}]}], "]"}]}], ";", 
      RowBox[{
       RowBox[{"coeffs", "\[LeftDoubleBracket]", 
        RowBox[{"m", "+", "1"}], "\[RightDoubleBracket]"}], "=", "x"}], ";", 
      RowBox[{"residual", "=", 
       RowBox[{"Expand", "[", 
        RowBox[{
         RowBox[{"IdentityResiduals", "[", 
          RowBox[{"coeffs", ",", 
           RowBox[{"2", " ", "m"}]}], "]"}], "\[LeftDoubleBracket]", 
         RowBox[{
          RowBox[{"2", " ", "m"}], "+", "1"}], "\[RightDoubleBracket]"}], 
        "]"}]}], ";", 
      RowBox[{"c0", "=", 
       RowBox[{"Coefficient", "[", 
        RowBox[{"residual", ",", "x", ",", "0"}], "]"}]}], ";", 
      RowBox[{"c1", "=", 
       RowBox[{"Coefficient", "[", 
        RowBox[{"residual", ",", "x", ",", "1"}], "]"}]}], ";", 
      RowBox[{"c2", "=", 
       RowBox[{"Coefficient", "[", 
        RowBox[{"residual", ",", "x", ",", "2"}], "]"}]}], ";", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"c0", "=!=", "0"}], "||", 
         RowBox[{"c1", "===", "0"}], "||", 
         RowBox[{"c2", "===", "0"}]}], ",", 
        RowBox[{"Return", "[", 
         RowBox[{"Failure", "[", 
          RowBox[{"\"\<DegenerateFirstConstraint\>\"", ",", 
           RowBox[{"Association", "[", 
            RowBox[{
             RowBox[{"\"\<m\>\"", "\[Rule]", "m"}], ",", 
             RowBox[{"\"\<Residual\>\"", "\[Rule]", "residual"}]}], "]"}]}], 
          "]"}], "]"}]}], "]"}], ";", 
      RowBox[{"Association", "[", 
       RowBox[{
        RowBox[{"\"\<CoefficientIndex\>\"", "\[Rule]", "m"}], ",", 
        RowBox[{"\"\<EquationPower\>\"", "\[Rule]", 
         RowBox[{"2", " ", "m"}]}], ",", 
        RowBox[{"\"\<ConstantTerm\>\"", "\[Rule]", "c0"}], ",", 
        RowBox[{"\"\<LinearTerm\>\"", "\[Rule]", "c1"}], ",", 
        RowBox[{"\"\<QuadraticTerm\>\"", "\[Rule]", "c2"}], ",", 
        RowBox[{"\"\<NonzeroSolution\>\"", "\[Rule]", 
         RowBox[{"-", 
          FractionBox["c1", "c2"]}]}]}], "]"}]}]}], "]"}]}], ";"}]], "Input",
 CellLabel->
  "4/21/26 13:56:19 \
In[35]:=",ExpressionUUID->"1c07b221-62e2-1b4b-960a-5966368177f9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"BuildAffineStep", "[", 
    RowBox[{"solved_List", ",", 
     RowBox[{"m_Integer", "?", "Positive"}], ",", 
     RowBox[{"j_Integer", "?", "Positive"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"equationPower", "=", 
        RowBox[{"m", "+", "j"}]}], ",", "coeffs", ",", "residual", ",", "c0", 
       ",", "c1"}], "}"}], ",", 
     RowBox[{
      RowBox[{"coeffs", "=", 
       RowBox[{"ConstantArray", "[", 
        RowBox[{"0", ",", 
         RowBox[{"equationPower", "+", "1"}]}], "]"}]}], ";", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"coeffs", "\[LeftDoubleBracket]", 
          RowBox[{"n", "+", "1"}], "\[RightDoubleBracket]"}], "=", 
         RowBox[{"Which", "[", 
          RowBox[{
           RowBox[{"n", "<", "j"}], ",", 
           RowBox[{"solved", "\[LeftDoubleBracket]", 
            RowBox[{"n", "+", "1"}], "\[RightDoubleBracket]"}], ",", 
           RowBox[{"n", "\[Equal]", "j"}], ",", "x", ",", "True", ",", "0"}], 
          "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "1", ",", "equationPower"}], "}"}]}], "]"}], ";", 
      RowBox[{"residual", "=", 
       RowBox[{"Expand", "[", 
        RowBox[{
         RowBox[{"IdentityResiduals", "[", 
          RowBox[{"coeffs", ",", "equationPower"}], "]"}], "\[LeftDoubleBracket]", 
         RowBox[{"equationPower", "+", "1"}], "\[RightDoubleBracket]"}], 
        "]"}]}], ";", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Exponent", "[", 
          RowBox[{"residual", ",", "x"}], "]"}], ">", "1"}], ",", 
        RowBox[{"Return", "[", 
         RowBox[{"Failure", "[", 
          RowBox[{"\"\<NonAffineConstraint\>\"", ",", 
           RowBox[{"Association", "[", 
            RowBox[{
             RowBox[{"\"\<m\>\"", "\[Rule]", "m"}], ",", 
             RowBox[{"\"\<j\>\"", "\[Rule]", "j"}], ",", 
             RowBox[{"\"\<Residual\>\"", "\[Rule]", "residual"}]}], "]"}]}], 
          "]"}], "]"}]}], "]"}], ";", 
      RowBox[{"c0", "=", 
       RowBox[{"Coefficient", "[", 
        RowBox[{"residual", ",", "x", ",", "0"}], "]"}]}], ";", 
      RowBox[{"c1", "=", 
       RowBox[{"Coefficient", "[", 
        RowBox[{"residual", ",", "x", ",", "1"}], "]"}]}], ";", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"c1", "===", "0"}], ",", 
        RowBox[{"Return", "[", 
         RowBox[{"Failure", "[", 
          RowBox[{"\"\<DegenerateAffineConstraint\>\"", ",", 
           RowBox[{"Association", "[", 
            RowBox[{
             RowBox[{"\"\<m\>\"", "\[Rule]", "m"}], ",", 
             RowBox[{"\"\<j\>\"", "\[Rule]", "j"}], ",", 
             RowBox[{"\"\<Residual\>\"", "\[Rule]", "residual"}]}], "]"}]}], 
          "]"}], "]"}]}], "]"}], ";", 
      RowBox[{"Association", "[", 
       RowBox[{
        RowBox[{"\"\<CoefficientIndex\>\"", "\[Rule]", "j"}], ",", 
        RowBox[{"\"\<EquationPower\>\"", "\[Rule]", "equationPower"}], ",", 
        RowBox[{"\"\<ConstantTerm\>\"", "\[Rule]", "c0"}], ",", 
        RowBox[{"\"\<LinearTerm\>\"", "\[Rule]", "c1"}], ",", 
        RowBox[{"\"\<SolvedValue\>\"", "\[Rule]", 
         RowBox[{"-", 
          FractionBox["c0", "c1"]}]}]}], "]"}]}]}], "]"}]}], ";"}]], "Input",
 CellLabel->
  "4/21/26 13:56:19 \
In[36]:=",ExpressionUUID->"b8e45686-729c-804c-b040-97e575b0c87b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"BuildBranchCertificate", "[", 
    RowBox[{
     RowBox[{"m_Integer", "?", "Positive"}], ",", 
     RowBox[{"order_Integer", "?", "Positive"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"first", ",", "solved", ",", 
       RowBox[{"steps", "=", 
        RowBox[{"{", "}"}]}], ",", "step", ",", "residual"}], "}"}], ",", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"order", "<", "m"}], ",", 
        RowBox[{"Return", "[", 
         RowBox[{"Failure", "[", 
          RowBox[{"\"\<OrderTooSmall\>\"", ",", 
           RowBox[{"Association", "[", 
            RowBox[{
             RowBox[{"\"\<m\>\"", "\[Rule]", "m"}], ",", 
             RowBox[{"\"\<Order\>\"", "\[Rule]", "order"}]}], "]"}]}], "]"}], 
         "]"}]}], "]"}], ";", 
      RowBox[{"first", "=", 
       RowBox[{"BuildFirstNonzeroConstraint", "[", "m", "]"}]}], ";", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"FailureQ", "[", "first", "]"}], ",", 
        RowBox[{"Return", "[", "first", "]"}]}], "]"}], ";", 
      RowBox[{"solved", "=", 
       RowBox[{"ZeroSolution", "[", "order", "]"}]}], ";", 
      RowBox[{
       RowBox[{"solved", "\[LeftDoubleBracket]", 
        RowBox[{"m", "+", "1"}], "\[RightDoubleBracket]"}], "=", 
       RowBox[{"first", "[", "\"\<NonzeroSolution\>\"", "]"}]}], ";", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"step", "=", 
          RowBox[{"BuildAffineStep", "[", 
           RowBox[{"solved", ",", "m", ",", "j"}], "]"}]}], ";", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"FailureQ", "[", "step", "]"}], ",", 
           RowBox[{"Return", "[", "step", "]"}]}], "]"}], ";", 
         RowBox[{
          RowBox[{"solved", "\[LeftDoubleBracket]", 
           RowBox[{"j", "+", "1"}], "\[RightDoubleBracket]"}], "=", 
          RowBox[{"step", "[", "\"\<SolvedValue\>\"", "]"}]}], ";", 
         RowBox[{"AppendTo", "[", 
          RowBox[{"steps", ",", "step"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", 
          RowBox[{"m", "+", "1"}], ",", "order"}], "}"}]}], "]"}], ";", 
      RowBox[{"residual", "=", 
       RowBox[{"IdentityResiduals", "[", 
        RowBox[{"solved", ",", "order"}], "]"}]}], ";", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"AllTrue", "[", 
          RowBox[{
           RowBox[{"Rest", "[", "residual", "]"}], ",", 
           RowBox[{
            RowBox[{"#1", "===", "0"}], "&"}]}], "]"}]}], ",", 
        RowBox[{"Return", "[", 
         RowBox[{"Failure", "[", 
          RowBox[{"\"\<ResidualCheckFailed\>\"", ",", 
           RowBox[{"Association", "[", 
            RowBox[{
             RowBox[{"\"\<m\>\"", "\[Rule]", "m"}], ",", 
             RowBox[{"\"\<Residual\>\"", "\[Rule]", "residual"}]}], "]"}]}], 
          "]"}], "]"}]}], "]"}], ";", 
      RowBox[{"Association", "[", 
       RowBox[{
        RowBox[{"\"\<MinimumIndex\>\"", "\[Rule]", "m"}], ",", 
        RowBox[{"\"\<FirstConstraint\>\"", "\[Rule]", "first"}], ",", 
        RowBox[{"\"\<AffineSteps\>\"", "\[Rule]", "steps"}], ",", 
        RowBox[{"\"\<Solution\>\"", "\[Rule]", "solved"}], ",", 
        RowBox[{"\"\<Residual\>\"", "\[Rule]", "residual"}]}], "]"}]}]}], 
    "]"}]}], ";", 
  RowBox[{
   RowBox[{"EnumerateNonzeroBranches", "[", 
    RowBox[{"order_Integer", "?", "Positive"}], "]"}], ":=", 
   RowBox[{"Association", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"m", "\[Rule]", 
       RowBox[{
        RowBox[{"BuildBranchCertificate", "[", 
         RowBox[{"m", ",", "order"}], "]"}], "[", "\"\<Solution\>\"", "]"}]}],
       ",", 
      RowBox[{"{", 
       RowBox[{"m", ",", "1", ",", "order"}], "}"}]}], "]"}], "]"}]}], ";", 
  RowBox[{
   RowBox[{"RunEnumerateOrder", "[", 
    RowBox[{"order_Integer", "?", "Positive"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
