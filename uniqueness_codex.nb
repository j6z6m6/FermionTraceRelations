      RowBox[{"branches", "=", 
       RowBox[{"Association", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"m", "\[Rule]", 
           RowBox[{
            RowBox[{"certificates", "[", "m", "]"}], "[", "\"\<Solution\>\"", 
