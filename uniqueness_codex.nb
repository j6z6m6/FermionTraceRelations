           RowBox[{"{", 
            RowBox[{"m", ",", "1", ",", "order"}], "}"}]}], "]"}], "]"}], 
        "]"}]}], ";", 
      RowBox[{"Association", "[", 
       RowBox[{
        RowBox[{"\"\<Summary\>\"", "\[Rule]", 
