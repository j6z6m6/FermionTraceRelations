Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"PE", "[", "f_", "]"}], "[", "x_", "]"}], ":=", 
  RowBox[{"Exp", "[", 
   RowBox[{"Sum", "[", 
    RowBox[{
     FractionBox[
      RowBox[{"f", "[", 
       SuperscriptBox["x", "k"], "]"}], "k"], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "\[Infinity]"}], "}"}]}], "]"}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"PEF", "[", "f_", "]"}], "[", "x_", "]"}], ":=", 
  RowBox[{"Exp", "[", 
   RowBox[{"-", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       FractionBox[
        RowBox[{"f", "[", 
         SuperscriptBox["x", "k"], "]"}], "k"], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], "k"]}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "\[Infinity]"}], "}"}]}], "]"}]}], 
   "]"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"PE", "[", 
    RowBox[{"f_", ",", "cutoff_"}], "]"}], "[", "x_", "]"}], ":=", 
  RowBox[{"Exp", "[", 
   RowBox[{"Sum", "[", 
    RowBox[{
     FractionBox[
      RowBox[{"f", "[", 
       SuperscriptBox["x", "k"], "]"}], "k"], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "cutoff"}], "}"}]}], "]"}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"PEF", "[", 
    RowBox[{"f_", ",", "cutoff_"}], "]"}], "[", "x_", "]"}], ":=", 
  RowBox[{"Exp", "[", 
   RowBox[{"-", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       FractionBox[
        RowBox[{"f", "[", 
         SuperscriptBox["x", "k"], "]"}], "k"], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], "k"]}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "cutoff"}], "}"}]}], "]"}]}], 
   "]"}]}]}], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"ebf16b72-2394-405d-b498-c3d49e2ef9d7"],

