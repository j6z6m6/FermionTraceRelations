Cell[BoxData[
 RowBox[{
  RowBox[{"is", "[", "x_", "]"}], ":=", 
  FractionBox[
   RowBox[{"-", "x"}], 
   RowBox[{"1", "-", "x"}]]}]], "Input",
 CellChangeTimes->{{3.909466030560563*^9, 3.909466039476509*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"8911ecef-61c3-4a4b-984d-c536c2ab7bc7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"isP", "[", 
   RowBox[{"n_", ",", "P_", ",", "x_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"part", "=", 
       RowBox[{
        RowBox[{"IntegerPartitions", "[", "n", "]"}], "[", 
        RowBox[{"[", "P", "]"}], "]"}]}], ",", 
      RowBox[{"m", "=", "0"}], ",", 
      RowBox[{"k", "=", "0"}]}], "}"}], ",", 
    RowBox[{
     RowBox[{"m", "=", 
      RowBox[{"Max", "[", "part", "]"}]}], ";", 
     RowBox[{"k", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "m"}], "}"}]}], "]"}]}], ";", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"k", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "=", 
        RowBox[{"Count", "[", 
         RowBox[{"part", ",", "i"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "m"}], "}"}]}], "]"}], ";", 
     RowBox[{"Product", "[", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"is", "[", 
         SuperscriptBox["x", "j"], "]"}], 
        RowBox[{"k", "[", 
         RowBox[{"[", "j", "]"}], "]"}]], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "m"}], "}"}]}], "]"}]}]}], 
   "]"}]}]], "Input",
 CellLabel->"In[8]:=",ExpressionUUID->"ff11b6b4-320e-4037-bc64-18d6e034375e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fast\[ScriptCapitalI]", "[", 
   RowBox[{"NN_", ",", "nmax_", ",", "x_"}], "]"}], ":=", 
  RowBox[{"1", "+", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"isP", "[", 
         RowBox[{"n", ",", "P", ",", "x"}], "]"}], "/", 
        RowBox[{"zP", "[", 
         RowBox[{"n", ",", "P"}], "]"}]}], ")"}], 
      RowBox[{"chsum", "[", 
       RowBox[{"NN", ",", "n", ",", "P"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "nmax"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"P", ",", "1", ",", 
       RowBox[{"PartitionsP", "[", "n", "]"}]}], "}"}]}], "]"}]}]}]], "Input",
 CellLabel->"In[9]:=",ExpressionUUID->"eb722ca4-cf6e-4271-82b8-b9194e20a0d0"]
}, Closed]],

