Cell[CellGroupData[{

Cell["Step 2 Combine single-traces to get multi-traces at N=\[Infinity]", \
"Section",
 CellChangeTimes->{{3.9168185836372795`*^9, 3.9168186121964846`*^9}, {
  3.916819305569397*^9, 
  3.916819307813091*^9}},ExpressionUUID->"dac27666-b674-4362-ae21-\
bfea0b802052"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
  "At", " ", "the", " ", "same", " ", "time", " ", "avoid", " ", "fermions", " ",
    "squared"}], "*)"}]], "Input",
 CellChangeTimes->{{3.916821442771107*^9, 3.916821454629901*^9}},
 CellLabel->"In[36]:=",ExpressionUUID->"43f7b88e-d5df-426e-afec-e9eaf1dc5382"],

Cell[CellGroupData[{

Cell["Step 2.1 we combine all single-traces", "Subsection",
 CellChangeTimes->{{3.916821466992488*^9, 3.916821482297162*^9}, {
  3.9168221973602376`*^9, 
  3.9168222194110107`*^9}},ExpressionUUID->"8956eae5-65b5-420e-9c81-\
08d844f5624f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"cy", ":=", 
   RowBox[{
    RowBox[{"Permute", "[", 
     RowBox[{"#", ",", 
      RowBox[{"CyclicGroup", "[", 
       RowBox[{"Length", "@", "#"}], "]"}]}], "]"}], "&"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"noncy", "[", "list_", "]"}], ":=", 
   RowBox[{"DeleteDuplicates", "[", 
    RowBox[{
     RowBox[{"Permutations", "[", "list", "]"}], ",", 
     RowBox[{
      RowBox[{"MemberQ", "[", 
       RowBox[{
        RowBox[{"cy", "[", "#1", "]"}], ",", "#2"}], "]"}], "&"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"singletracelist", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"charge", ",", 
       RowBox[{
        RowBox[{"ptlist", "=", 
         RowBox[{"IntegerPartitions", "[", "charge", "]"}]}], ";", 
        RowBox[{"listofeverything", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"ptlist", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{"Length", "[", "ptlist", "]"}]}], "}"}]}], "]"}]}], ";", 
        RowBox[{"listcyclic", "=", 
         RowBox[{
          RowBox[{"Flatten", "[", 
           RowBox[{
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"temp", "=", 
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"noncy", "[", 
                   RowBox[{
                    RowBox[{"listofeverything", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "]"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"j", ",", "1", ",", 
                    RowBox[{"Length", "[", 
                    RowBox[{"listofeverything", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "]"}]}], "}"}]}], "]"}]}],
                ";", "\[IndentingNewLine]", 
               RowBox[{"Tuples", "[", "temp", "]"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", "1", ",", 
                RowBox[{"Length", "[", "listofeverything", "]"}]}], "}"}]}], 
             "]"}], ",", "1"}], "]"}], "//", "DeleteDuplicates"}]}], ";", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"FindRepeat", "[", 
              RowBox[{"listcyclic", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "]"}], "!=", 
             RowBox[{"listcyclic", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], ",", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"EvenQ", "[", 
                FractionBox[
                 RowBox[{"Length", "[", 
                  RowBox[{
                   RowBox[{"listcyclic", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", 
                   RowBox[{"[", "1", "]"}], "]"}], "]"}], 
                 RowBox[{"Length", "[", 
                  RowBox[{
                   RowBox[{"FindRepeat", "[", 
                    RowBox[{"listcyclic", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "]"}], "[", 
                   RowBox[{"[", "1", "]"}], "]"}], "]"}]], "]"}], 
               RowBox[{"(*", 
                RowBox[{
                 RowBox[{
                 "This", " ", "says", " ", "the", " ", "pure", " ", "power", " ",
                   "is", " ", 
                  RowBox[{"even", ".", " ", "Note"}], " ", "that", " ", 
                  "this", " ", "also", " ", "cures", " ", "a", " ", "defect", 
                  " ", "that", " ", "FindRepeat", " ", "does", " ", "not", " ",
                   "require", " ", "the", " ", "last", " ", "sublist", " ", 
                  "to", " ", "be", " ", "repeated", " ", "completely"}], 
                 "..."}], "*)"}], "&&", 
               RowBox[{"OddQ", "[", 
                RowBox[{"Length", "[", 
                 RowBox[{
                  RowBox[{"FindRepeat", "[", 
                   RowBox[{"listcyclic", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "]"}], "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}]}], 
              RowBox[{"(*", 
               RowBox[{
               "This", " ", "says", " ", "the", " ", "repeated", " ", 
                "pattern", " ", "is", " ", "a", " ", "fermion"}], "*)"}], ",",
               "Nothing", ",", 
              RowBox[{"listcyclic", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
            RowBox[{"listcyclic", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"Length", "[", "listcyclic", "]"}]}], "}"}]}], "]"}]}]}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"charge", ",", "1", ",", "10"}], "}"}]}], "]"}]}], 
  ";"}]}], "Input",
 CellLabel->"In[37]:=",ExpressionUUID->"e11f3ab0-f2af-4770-8d3f-5e5f1b2c74fb"],

