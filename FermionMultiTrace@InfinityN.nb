Cell[CellGroupData[{

Cell["\<\
Step 1.4 Combine all the steps to give complete set of single-traces and do a \
check of index\
\>", "Subsection",
 CellChangeTimes->{{3.9168203053274593`*^9, 
  3.916820327720869*^9}},ExpressionUUID->"dba42a8a-5175-45db-a03c-\
fe4372781f48"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"cy", ":=", 
   RowBox[{
    RowBox[{"Permute", "[", 
     RowBox[{"#", ",", 
      RowBox[{"CyclicGroup", "[", 
       RowBox[{"Length", "@", "#"}], "]"}]}], "]"}], "&"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"noncy", "[", "list_", "]"}], ":=", 
   RowBox[{"DeleteDuplicates", "[", 
    RowBox[{
     RowBox[{"Permutations", "[", "list", "]"}], ",", 
     RowBox[{
      RowBox[{"MemberQ", "[", 
       RowBox[{
        RowBox[{"cy", "[", "#1", "]"}], ",", "#2"}], "]"}], "&"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"singletracelist", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"charge", ",", 
       RowBox[{
        RowBox[{"ptlist", "=", 
         RowBox[{"IntegerPartitions", "[", "charge", "]"}]}], ";", 
        RowBox[{"listofeverything", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"ptlist", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{"Length", "[", "ptlist", "]"}]}], "}"}]}], "]"}]}], ";", 
        RowBox[{"listcyclic", "=", 
         RowBox[{
          RowBox[{"Flatten", "[", 
           RowBox[{
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"temp", "=", 
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"noncy", "[", 
                   RowBox[{
                    RowBox[{"listofeverything", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "]"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"j", ",", "1", ",", 
                    RowBox[{"Length", "[", 
                    RowBox[{"listofeverything", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "]"}]}], "}"}]}], "]"}]}],
                ";", "\[IndentingNewLine]", 
               RowBox[{"Tuples", "[", "temp", "]"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", "1", ",", 
                RowBox[{"Length", "[", "listofeverything", "]"}]}], "}"}]}], 
             "]"}], ",", "1"}], "]"}], "//", "DeleteDuplicates"}]}], ";", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"FindRepeat", "[", 
              RowBox[{"listcyclic", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "]"}], "!=", 
             RowBox[{"listcyclic", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], ",", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"EvenQ", "[", 
                FractionBox[
                 RowBox[{"Length", "[", 
                  RowBox[{
                   RowBox[{"listcyclic", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", 
                   RowBox[{"[", "1", "]"}], "]"}], "]"}], 
                 RowBox[{"Length", "[", 
                  RowBox[{
                   RowBox[{"FindRepeat", "[", 
                    RowBox[{"listcyclic", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "]"}], "[", 
                   RowBox[{"[", "1", "]"}], "]"}], "]"}]], "]"}], 
               RowBox[{"(*", 
                RowBox[{
                 RowBox[{
                 "This", " ", "says", " ", "the", " ", "pure", " ", "power", " ",
                   "is", " ", 
                  RowBox[{"even", ".", " ", "Note"}], " ", "that", " ", 
                  "this", " ", "also", " ", "cures", " ", "a", " ", "defect", 
                  " ", "that", " ", "FindRepeat", " ", "does", " ", "not", " ",
                   "require", " ", "the", " ", "last", " ", "sublist", " ", 
                  "to", " ", "be", " ", "repeated", " ", "completely"}], 
                 "..."}], "*)"}], "&&", 
               RowBox[{"OddQ", "[", 
                RowBox[{"Length", "[", 
                 RowBox[{
                  RowBox[{"FindRepeat", "[", 
                   RowBox[{"listcyclic", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "]"}], "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}]}], 
              RowBox[{"(*", 
               RowBox[{
               "This", " ", "says", " ", "the", " ", "repeated", " ", 
                "pattern", " ", "is", " ", "a", " ", "fermion"}], "*)"}], ",",
               "Nothing", ",", 
              RowBox[{"listcyclic", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
            RowBox[{"listcyclic", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"Length", "[", "listcyclic", "]"}]}], "}"}]}], "]"}]}]}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"charge", ",", "1", ",", "10"}], "}"}]}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9168203439574175`*^9, 3.916820457657869*^9}, {
  3.9168205479795685`*^9, 3.9168206325677032`*^9}, {3.9168213437433205`*^9, 
