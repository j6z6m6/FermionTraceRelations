Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{
     "from", " ", "permutations", " ", "inside", " ", "a", " ", "single"}], "-", 
     RowBox[{
      RowBox[{"trace", ".", " ", "All"}], " ", "are", " ", "fermions"}]}], ",",
     " ", 
    RowBox[{"it", " ", "depends", " ", "all", " ", "on", " ", "the", " ", 
     RowBox[{"cycles", "!"}]}]}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Sign", " ", "from", " ", "permutations", " ", "inside", " ", "the", " ", 
     RowBox[{"trace", ".", " ", "If"}], " ", "numebr", " ", "of", " ", 
     "fermions", " ", "is", " ", "odd"}], ",", " ", 
    RowBox[{
    "then", " ", "all", " ", "cycles", " ", "involve", " ", "even", " ", 
     "number", " ", "of", " ", "fermion", " ", "moves"}], ",", " ", 
    RowBox[{
     RowBox[{"so", " ", "no", " ", "sign"}], ";", " ", 
     RowBox[{
     "if", " ", "the", " ", "number", " ", "of", " ", "fermions", " ", "is", " ",
       "even"}]}], ",", " ", 
    RowBox[{
    "one", " ", "need", " ", "to", " ", "track", " ", "the", " ", "number", " ",
      "of", " ", "odd", " ", "cycles", " ", "used"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"CycleSignature", "[", "perm_List", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"temp", "=", 
        RowBox[{
         RowBox[{"CanonicalOrderSingleTrace", "[", 
          RowBox[{"{", "perm", "}"}], "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ",", 
       RowBox[{"index", "=", "0"}], ",", 
       RowBox[{"cycle", "=", "0"}]}], "}"}], ",", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", "perm", "]"}], "//", "OddQ"}], ",", "1", ",", 
       RowBox[{"(*", 
        RowBox[{
        "First", " ", "find", " ", "the", " ", "cycle", " ", "that", " ", 
         "permute", " ", "perm", " ", "to", " ", "canonical"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"index", "=", 
         RowBox[{
          RowBox[{"Position", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"Permute", "[", 
               RowBox[{"perm", ",", "#"}], "]"}], "&"}], "/@", 
             RowBox[{"GroupElements", "[", 
              RowBox[{"CyclicGroup", "[", 
               RowBox[{"Length", "[", "perm", "]"}], "]"}], "]"}]}], ",", 
            "temp"}], "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Then", " ", "we", " ", "take", " ", "the", " ", "Signature", " ", 
          "of", " ", "this", " ", "permutation"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"cycle", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"GroupElements", "[", 
            RowBox[{"CyclicGroup", "[", 
             RowBox[{"Length", "[", "perm", "]"}], "]"}], "]"}], "[", 
           RowBox[{"[", "index", "]"}], "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Permute", "[", 
          RowBox[{
           RowBox[{"Range", "[", 
            RowBox[{"Length", "[", "perm", "]"}], "]"}], ",", "cycle"}], 
          "]"}], "//", "Signature"}]}]}], "\[IndentingNewLine]", "]"}]}], 
    "]"}]}]}]], "Input",
 CellChangeTimes->{{3.938879052279602*^9, 3.9388791279614086`*^9}, {
