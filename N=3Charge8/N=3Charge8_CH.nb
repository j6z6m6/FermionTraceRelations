Cell[BoxData[
 RowBox[{
  RowBox[{"ListSignatureBF", "[", "perm_List", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"count", "=", "0"}], ",", 
      RowBox[{"n", "=", 
       RowBox[{"Length", "[", "perm", "]"}]}]}], "}"}], ",", 
    RowBox[{
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Not", "[", 
             RowBox[{"OrderedQ", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"perm", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], ",", 
                RowBox[{"perm", "[", 
                 RowBox[{"[", "j", "]"}], "]"}]}], "}"}], "]"}], "]"}], "&&", 
            RowBox[{"OddQ", "[", 
             RowBox[{"Length", "[", 
              RowBox[{"perm", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "]"}], "]"}], "&&", 
            RowBox[{"OddQ", "[", 
             RowBox[{"Length", "[", 
              RowBox[{"perm", "[", 
               RowBox[{"[", "j", "]"}], "]"}], "]"}], "]"}]}], ",", 
           RowBox[{"count", "=", 
            RowBox[{"Mod", "[", 
             RowBox[{
              RowBox[{"count", "+", "1"}], ",", "2"}], "]"}]}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", 
           RowBox[{"i", "+", "1"}], ",", "n"}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", 
         RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"count", "==", "0"}], ",", "1", ",", 
       RowBox[{"-", "1"}]}], "]"}]}]}], "]"}], 
  RowBox[{"(*", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Custom", " ", "defined", " ", "signature", " ", "function", " ", "to", " ",
       "compute", " ", "the", " ", "signature", " ", "of", " ", "a", " ", 
      "permutation", " ", "that", " ", "brings", " ", "a", " ", "sequence", " ",
       "to", " ", "its", " ", "canonical", " ", "order"}], ";", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"the", " ", "built"}], "-", 
       RowBox[{
       "in", " ", "MMA", " ", "Signature", " ", "function", " ", "cannot", " ",
         "deal", " ", "with", " ", "repeated", " ", "elements", " ", "the", " ",
         "way", " ", "we", " ", "want"}]}], "..."}]}], "*)"}], 
   RowBox[{
    RowBox[{
    "this", " ", "will", " ", "be", " ", "used", " ", "to", " ", "commute", " ",
      "single"}], "-", 
    RowBox[{"trace", " ", "operators", " ", "in", " ", "a", " ", "multi"}], "-", 
    RowBox[{
     RowBox[{"trace", ".", " ", "bosons"}], " ", "and", " ", "fermions", " ", 
     "are", " ", "taken", " ", "care", " ", "of"}]}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.938877567052948*^9, 3.9388776627631283`*^9}, {
   3.938877897627466*^9, 3.9388779006881886`*^9}, {3.938877973998247*^9, 
