Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Function", ":", "RowReduceWithCombinations"}], "*)"}], 
  RowBox[{
   RowBox[{"RowReduceWithCombinations", "[", 
    RowBox[{"matrix_", "?", "MatrixQ"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "A", ",", "C", ",", "nRows", ",", "nCols", ",", "pivotRow", ",", 
       "pivotCol", ",", "pivot", ",", "scale", ",", "i", ",", "factor", ",", 
       "pos", ",", "operations"}], "}"}], ",", 
     RowBox[{"(*", 
      RowBox[{
      "Initialize", " ", "the", " ", "original", " ", "matrix", " ", "and", " ",
        "coefficient", " ", "matrix"}], "*)"}], 
     RowBox[{
      RowBox[{"A", "=", "matrix"}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"nRows", ",", "nCols"}], "}"}], "=", 
       RowBox[{"Dimensions", "[", "A", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"C", "=", 
       RowBox[{"IdentityMatrix", "[", "nRows", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"operations", "=", 
       RowBox[{"{", "}"}]}], ";", 
      RowBox[{"(*", 
       RowBox[{
       "To", " ", "store", " ", "the", " ", "sequence", " ", "of", " ", "row",
         " ", "operations"}], "*)"}], 
      RowBox[{"pivotRow", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{"pivotCol", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"pivotRow", "<=", "nRows"}], "&&", 
         RowBox[{"pivotCol", "<=", "nCols"}]}], ",", 
        RowBox[{"(*", 
         RowBox[{
         "Extract", " ", "the", " ", "current", " ", "pivot", " ", "column", " ",
           "from", " ", "the", " ", "current", " ", "pivot", " ", "row", " ", 
          "downwards"}], "*)"}], 
        RowBox[{
         RowBox[{"pivot", "=", 
          RowBox[{"A", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"pivotRow", ";;"}], ",", "pivotCol"}], "]"}], "]"}]}], ";",
          "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"Find", " ", "the", " ", "first", " ", "non"}], "-", 
           RowBox[{
           "zero", " ", "entry", " ", "in", " ", "the", " ", "current", " ", 
            "pivot", " ", "column"}]}], "*)"}], 
         RowBox[{"pos", "=", 
          RowBox[{"FirstPosition", "[", 
           RowBox[{"pivot", ",", 
            RowBox[{"x_", "/;", 
             RowBox[{"x", "!=", "0"}]}], ",", 
            RowBox[{"Missing", "[", "]"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"pos", "===", 
            RowBox[{"Missing", "[", "]"}]}], ",", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{
             "No", " ", "pivot", " ", "in", " ", "this", " ", "column"}], ",", 
             RowBox[{
             "move", " ", "to", " ", "the", " ", "next", " ", "column"}]}], 
            "*)"}], 
           RowBox[{"pivotCol", "++"}], ",", 
           RowBox[{"(*", 
            RowBox[{"Pivot", " ", "found"}], "*)"}], 
           RowBox[{"Module", "[", 
            RowBox[{
             RowBox[{"{", "actualRow", "}"}], ",", 
             RowBox[{
              RowBox[{"actualRow", "=", 
               RowBox[{"pivotRow", "+", 
                RowBox[{"pos", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "-", "1"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
                RowBox[{
                "If", " ", "the", " ", "pivot", " ", "is", " ", "not", " ", 
                 "already", " ", "in", " ", "the", " ", "pivotRow"}], ",", 
                RowBox[{
                "swap", " ", "rows", " ", "in", " ", "both", " ", "A", " ", 
                 "and", " ", "C"}]}], "*)"}], 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"actualRow", "!=", "pivotRow"}], ",", 
                RowBox[{
                 RowBox[{
                  RowBox[{"A", "[", 
                   RowBox[{"[", 
                    RowBox[{"{", 
                    RowBox[{"pivotRow", ",", "actualRow"}], "}"}], "]"}], 
                   "]"}], "=", 
                  RowBox[{"A", "[", 
                   RowBox[{"[", 
                    RowBox[{"{", 
                    RowBox[{"actualRow", ",", "pivotRow"}], "}"}], "]"}], 
                   "]"}]}], ";", "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"C", "[", 
                   RowBox[{"[", 
                    RowBox[{"{", 
                    RowBox[{"pivotRow", ",", "actualRow"}], "}"}], "]"}], 
                   "]"}], "=", 
                  RowBox[{"C", "[", 
                   RowBox[{"[", 
                    RowBox[{"{", 
                    RowBox[{"actualRow", ",", "pivotRow"}], "}"}], "]"}], 
                   "]"}]}], ";", "\[IndentingNewLine]", 
                 RowBox[{"AppendTo", "[", 
                  RowBox[{"operations", ",", 
                   RowBox[{"{", 
                    
                    RowBox[{"\"\<Swap\>\"", ",", "pivotRow", ",", 
                    "actualRow"}], "}"}]}], "]"}], ";"}]}], "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
               "Update", " ", "the", " ", "pivot", " ", "after", " ", 
                "potential", " ", "row", " ", "swap"}], "*)"}], 
              RowBox[{"pivot", "=", 
               RowBox[{"A", "[", 
